<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.SET_WALLPAPER" />
    <uses-permission android:name="android.permission.BIND_WALLPAPER" tools:ignore="ProtectedPermissions" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Kennys_dokidoki_wallpaper"
        android:usesCleartextTraffic="true">
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".AlbumDetailActivity"
            android:exported="false" />
        <activity
            android:name=".ChubBrowserActivity"
            android:exported="false" />
        <activity
            android:name=".CustomFilePickerActivity"
            android:exported="false" />
        <activity
            android:name=".ImagePreviewActivity"
            android:exported="false" />
        <activity
            android:name=".CustomCropActivity"
            android:theme="@style/Theme.AppCompat.NoActionBar"
            android:exported="false" />

        <activity
            android:name=".CropHandlerActivity"
            android:theme="@style/Theme.TransparentOverlay"
            android:exported="false"
            android:taskAffinity=""
            android:excludeFromRecents="true" />

        <activity
            android:name=".ImageTagEditorActivity"
            android:theme="@style/Theme.TagEditorOverlay"
            android:exported="false"
            android:taskAffinity=""
            android:excludeFromRecents="true" />

        <activity
            android:name=".TapSettingsActivity"
            android:exported="false" />
        <activity
            android:name=".TagPromptEditorActivity"
            android:exported="false" />

        <!-- ローカルLLM管理画面を登録したわよ！ -->
        <activity
            android:name=".LocalModelActivity"
            android:exported="false" />

        <activity
            android:name=".GenerationProgressActivity"
            android:configChanges="screenSize|smallestScreenSize|screenLayout|orientation"
            android:supportsPictureInPicture="true"
            android:launchMode="singleInstance"
            android:exported="false"
            android:theme="@style/Theme.AppCompat.NoActionBar" />

        <activity
            android:name=".ChatOverlayActivity"
            android:theme="@style/Theme.TransparentOverlay"
            android:exported="false"
            android:taskAffinity=""
            android:excludeFromRecents="true"
            android:launchMode="singleInstance"
            android:windowSoftInputMode="stateHidden|adjustResize" />

        <activity
            android:name=".FullScreenImageActivity"
            android:theme="@style/Theme.AppCompat.NoActionBar"
            android:exported="false" />

        <activity
            android:name=".InspectionActivity"
            android:theme="@style/Theme.AppCompat.NoActionBar"
            android:exported="false" />

        <activity
            android:name="com.canhub.cropper.CropImageActivity"
            android:theme="@style/Base.Theme.AppCompat" />

        <service
            android:name=".MyWallpaperService"
            android:label="@string/app_name"
            android:permission="android.permission.BIND_WALLPAPER"
            android:exported="true">
            <intent-filter>
                <action android:name="android.service.wallpaper.WallpaperService" />
            </intent-filter>
            <meta-data
                android:name="android.service.wallpaper"
                android:resource="@xml/wallpaper" />
        </service>

        <!-- 画像生成用フォアグラウンドサービス -->
        <service
            android:name=".GenerationService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!-- ローカルLLM推論用フォアグラウンドサービス -->
        <service
            android:name=".LlmForegroundService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />
    </application>

</manifest>
