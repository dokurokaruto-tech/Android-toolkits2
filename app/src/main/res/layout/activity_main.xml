<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <!-- 複数選択モード用のアクションバー -->
    <LinearLayout
        android:id="@+id/selection_action_bar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="#1A2235"
        android:orientation="horizontal"
        android:padding="8dp"
        android:gravity="center_vertical"
        android:visibility="gone"
        android:elevation="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btn_selection_close"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="#FFFFFF" />

        <TextView
            android:id="@+id/tv_selection_count"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="1 selected"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginStart="16dp"
            tools:ignore="HardcodedText" />

        <Button
            android:id="@+id/btn_select_all"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="すべて選択"
            android:textColor="#00F0FF"
            android:textStyle="bold"
            android:backgroundTint="#00000000"
            tools:ignore="HardcodedText" />

        <ImageButton
            android:id="@+id/btn_selection_inspect"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@android:drawable/ic_menu_view"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="#00F0FF" />

        <ImageButton
            android:id="@+id/btn_selection_tag"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@android:drawable/ic_menu_edit"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="#00F0FF" />

        <ImageButton
            android:id="@+id/btn_selection_delete"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@android:drawable/ic_menu_delete"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="#FF3366" />
    </LinearLayout>

    <!-- 操作バーのコンテナ -->
    <LinearLayout
        android:id="@+id/action_bar_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/selection_action_bar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 全画像タブ専用の操作バー -->
        <LinearLayout
            android:id="@+id/all_images_action_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="8dp"
            android:background="#0D1117"
            android:visibility="visible">

            <ImageButton
                android:id="@+id/btn_priority_sort"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_persona_item"
                android:src="@android:drawable/stat_notify_sync"
                app:tint="#00F0FF"
                android:contentDescription="優先度順に並べ替え"
                tools:ignore="HardcodedText" />

            <TextView
                android:id="@+id/tv_filter_count"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:text=""
                android:textColor="#8892B0"
                android:textSize="12sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btn_quick_sort"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginEnd="8dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="クイックソート"
                android:textColor="#00F0FF"
                android:textSize="12sp"
                android:textAllCaps="false"
                android:background="@drawable/bg_persona_item"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                tools:ignore="HardcodedText" />

            <ImageButton
                android:id="@+id/btn_sort_direction"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginEnd="16dp"
                android:background="@drawable/bg_persona_item"
                android:src="@android:drawable/arrow_up_float"
                app:tint="#00F0FF" />

            <CheckBox
                android:id="@+id/cb_show_tags"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="タグ表示"
                android:textColor="#8892B0"
                android:button="@drawable/checkbox_minimal_selector"
                android:paddingStart="6dp"
                android:textSize="11sp"
                android:minHeight="0dp"
                android:minWidth="0dp"
                tools:ignore="HardcodedText" />
        </LinearLayout>

        <!-- イメージセットタブ専用の操作バー -->
        <LinearLayout
            android:id="@+id/image_sets_action_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="8dp"
            android:background="#0D1117"
            android:visibility="gone">

            <TextView
                android:id="@+id/tv_sets_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="16dp"
                android:text="イメージセット"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <FrameLayout
        android:id="@+id/nav_host_content"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/bottom_navigation"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/action_bar_container">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_view_sets"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="80dp"
            android:visibility="gone"
            android:scrollbars="vertical" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_view_all_images"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="80dp"
            android:visibility="visible"
            android:scrollbars="vertical" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_view_tag_prompts"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:padding="8dp"
            android:paddingBottom="80dp"
            android:visibility="gone" />

        <!-- Prompt-Builder 画面 -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/layout_builder"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            android:fillViewport="true">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:id="@+id/ll_builder_top"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical"
                    app:layout_constraintTop_toTopOf="parent">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Prompt-Builder"
                        android:textColor="#00F0FF"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        tools:ignore="HardcodedText" />

                    <Button
                        android:id="@+id/btn_switch_columns"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="2列"
                        android:textSize="12sp"
                        android:textColor="#00F0FF"
                        android:layout_marginEnd="8dp"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:background="@drawable/bg_persona_item"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        tools:ignore="HardcodedText" />

                    <Button
                        android:id="@+id/btn_restore_pip"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_marginEnd="8dp"
                        android:padding="0dp"
                        android:text="🖼️"
                        android:textSize="16sp"
                        android:background="@drawable/bg_persona_item"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:visibility="gone"
                        tools:ignore="HardcodedText" />

                    <Button
                        android:id="@+id/btn_view_generated"
                        android:layout_width="64dp"
                        android:layout_height="36dp"
                        android:padding="0dp"
                        android:text="閲覧"
                        android:textSize="12sp"
                        android:textColor="#00F0FF"
                        android:background="@drawable/bg_persona_item"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        tools:ignore="HardcodedText" />

                    <Button
                        android:id="@+id/btn_generate_concatenated_top"
                        android:layout_width="64dp"
                        android:layout_height="36dp"
                        android:layout_marginStart="8dp"
                        android:padding="0dp"
                        android:text="生成"
                        android:textSize="12sp"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#00F0FF"
                        style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                        tools:ignore="HardcodedText" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layout_gen_settings"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingBottom="12dp"
                    android:background="#0D1117"
                    app:layout_constraintTop_toBottomOf="@id/ll_builder_top">

                    <HorizontalScrollView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:scrollbars="none">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <LinearLayout android:id="@+id/btn_setting_resolution" android:layout_width="wrap_content" android:layout_height="32dp" android:background="@drawable/bg_persona_item" android:paddingHorizontal="10dp" android:gravity="center"><TextView android:id="@+id/tv_setting_resolution" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="720 x 1280" android:textColor="#00F0FF" android:textSize="11sp" android:textStyle="bold" /></LinearLayout>
                            <LinearLayout android:id="@+id/btn_setting_steps" android:layout_width="wrap_content" android:layout_height="32dp" android:layout_marginStart="8dp" android:background="@drawable/bg_persona_item" android:paddingHorizontal="10dp" android:gravity="center"><TextView android:id="@+id/tv_setting_steps" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Steps: 20" android:textColor="#00F0FF" android:textSize="11sp" /></LinearLayout>
                            <LinearLayout android:id="@+id/btn_setting_batch" android:layout_width="wrap_content" android:layout_height="32dp" android:layout_marginStart="8dp" android:background="@drawable/bg_persona_item" android:paddingHorizontal="10dp" android:gravity="center"><TextView android:id="@+id/tv_setting_batch" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Batch: 1" android:textColor="#00F0FF" android:textSize="11sp" /></LinearLayout>
                            <LinearLayout android:id="@+id/btn_setting_sampler" android:layout_width="wrap_content" android:layout_height="32dp" android:layout_marginStart="8dp" android:background="@drawable/bg_persona_item" android:paddingHorizontal="10dp" android:gravity="center"><TextView android:id="@+id/tv_setting_sampler" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Euler a" android:textColor="#00F0FF" android:textSize="11sp" /></LinearLayout>
                        </LinearLayout>
                    </HorizontalScrollView>

                    <ImageButton
                        android:id="@+id/btn_reset_builder"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_marginStart="8dp"
                        android:src="@android:drawable/ic_menu_revert"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        app:tint="#8892B0"
                        android:contentDescription="設定のリセット"
                        tools:ignore="HardcodedText" />
                </LinearLayout>

                <!-- プリセットセクション -->
                <TextView
                    android:id="@+id/tv_presets_header"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="▼ プリセット"
                    android:textColor="#8892B0"
                    android:textSize="12sp"
                    android:paddingStart="16dp"
                    android:layout_marginTop="8dp"
                    app:layout_constraintTop_toBottomOf="@id/layout_gen_settings"
                    app:layout_constraintStart_toStartOf="parent" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recycler_view_presets"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false"
                    android:padding="8dp"
                    app:layout_constraintTop_toBottomOf="@id/tv_presets_header" />

                <!-- カードセクション -->
                <TextView
                    android:id="@+id/tv_cards_header"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="▼ プロンプトカード"
                    android:textColor="#8892B0"
                    android:textSize="12sp"
                    android:paddingStart="16dp"
                    android:layout_marginTop="16dp"
                    app:layout_constraintTop_toBottomOf="@id/recycler_view_presets"
                    app:layout_constraintStart_toStartOf="parent" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recycler_view_prompt_cards"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false"
                    android:padding="8dp"
                    android:paddingBottom="100dp"
                    app:layout_constraintTop_toBottomOf="@id/tv_cards_header" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.core.widget.NestedScrollView>

        <TextView
            android:id="@+id/content_placeholder"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Hello World!"
            android:visibility="gone"
            tools:ignore="HardcodedText" />
    </FrameLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_add_album"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:contentDescription="@string/add_album"
        app:layout_constraintBottom_toTopOf="@id/bottom_navigation"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:srcCompat="@android:drawable/ic_input_add"
        android:backgroundTint="#4A148C"
        app:tint="#FFFFFF" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_add_prompt_category"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/bottom_navigation"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:srcCompat="@android:drawable/ic_input_add"
        android:backgroundTint="#4A148C"
        app:tint="#FFFFFF"
        android:contentDescription="新しいカテゴリーを追加"
        tools:ignore="HardcodedText" />

    <!-- プリセット追加ボタンも同じ位置に配置するわね -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_add_preset"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/bottom_navigation"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:srcCompat="@android:drawable/ic_menu_save"
        android:backgroundTint="#00F0FF"
        app:tint="#0D1117"
        android:contentDescription="現在の状態をプリセット保存"
        tools:ignore="HardcodedText" />

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_navigation"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurface"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:menu="@menu/bottom_nav_menu" />

</androidx.constraintlayout.widget.ConstraintLayout>
