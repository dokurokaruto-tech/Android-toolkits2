<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_persona_dialog"
    android:padding="20dp">

    <!-- タイトル -->
    <TextView
        android:id="@+id/tv_dialog_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="✨ 指示内容の編集"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="12dp" />

    <!-- 説明文 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="AIキャラへの詳しい指示をここに記述してね♪"
        android:textColor="#CCFFFFFF"
        android:textSize="12sp"
        android:layout_marginBottom="10dp" />

    <!-- 指示内容編集エリア（大きなEditText） -->
    <EditText
        android:id="@+id/et_instruction_detail"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="180dp"
        android:background="@drawable/bg_persona_item"
        android:hint="例: ユーザーのことは『ケニー』と呼んで、優しくてちょっと照れ屋な態度で接してね！"
        android:textColor="#FFFFFF"
        android:textColorHint="#55FFFFFF"
        android:textSize="14sp"
        android:padding="16dp"
        android:gravity="top|start"
        android:inputType="textMultiLine"
        android:scrollbars="vertical"
        android:layout_marginBottom="16dp" />

    <!-- ボタンエリア -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <TextView
            android:id="@+id/btn_cancel_instruction"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:gravity="center"
            android:text="キャンセル"
            android:textColor="#88FFFFFF"
            android:textSize="14sp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/btn_save_instruction"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:gravity="center"
            android:text="確定"
            android:textColor="#00F0FF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginStart="8dp"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

</LinearLayout>
