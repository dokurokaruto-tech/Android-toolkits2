<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E60D1117"
    android:padding="16dp">

    <!-- タイトルバー -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="壁紙の属性（タグ）編集"
        android:textColor="#00F0FF"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- イメージセット編集用の追加要素を入れるコンテナ -->
    <LinearLayout
        android:id="@+id/header_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tv_title" />

    <!-- 画像プレビューと基本情報 -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_image_preview"
        android:layout_width="100dp"
        android:layout_height="140dp"
        android:layout_marginTop="8dp"
        app:cardBackgroundColor="#000000"
        app:cardCornerRadius="8dp"
        app:cardElevation="4dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/header_container">

        <ImageView
            android:id="@+id/iv_editor_preview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            tools:ignore="ContentDescription"
            tools:src="@android:drawable/ic_menu_gallery" />
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:id="@+id/image_info_layout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="@id/card_image_preview"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/card_image_preview"
        app:layout_constraintTop_toTopOf="@id/card_image_preview">

        <TextView
            android:id="@+id/tv_image_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="現在のキャラクター構成"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="タグを選択すると、AIへの指示（プロンプト）がリアルタイムで構築されます。"
            android:textColor="#8892B0"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btn_add_new_tag"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="+ 新しいタグを作成"
            android:textColor="#00F0FF"
            android:textSize="12sp" />
    </LinearLayout>

    <View
        android:id="@+id/divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="16dp"
        android:background="#2D3748"
        app:layout_constraintTop_toBottomOf="@id/card_image_preview" />

    <!-- タグ選択エリア -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_tag_picker"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toTopOf="@id/layout_buttons"
        app:layout_constraintTop_toBottomOf="@id/divider"
        tools:listitem="@layout/item_tag_picker_chip" />

    <!-- 下部ボタン -->
    <LinearLayout
        android:id="@+id/layout_buttons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent">

        <Button
            android:id="@+id/btn_cancel"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:text="キャンセル"
            android:textColor="#8892B0"
            app:strokeColor="#2D3748" />

        <Button
            android:id="@+id/btn_direct_description"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginHorizontal="4dp"
            android:layout_weight="1.5"
            android:text="画像個別設定"
            android:textColor="#00F0FF"
            android:textSize="12sp"
            app:strokeColor="#00F0FF" />

        <Button
            android:id="@+id/btn_save"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginStart="4dp"
            android:layout_weight="2"
            android:backgroundTint="#00F0FF"
            android:text="設定を保存して適用"
            android:textColor="#000000"
            android:textStyle="bold" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
