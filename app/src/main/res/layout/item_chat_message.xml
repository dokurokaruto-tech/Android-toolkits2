<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/chat_message_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:paddingHorizontal="16dp"
    android:paddingVertical="4dp">

    <!-- AIメッセージコンテナ -->
    <LinearLayout
        android:id="@+id/container_ai"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="start"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/bubble_ai"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_chat_bubble_ai"
            android:orientation="vertical"
            android:gravity="start"
            android:paddingHorizontal="14dp"
            android:paddingVertical="10dp">

            <TextView
                android:id="@+id/text_message_ai"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@android:color/white"
                android:textSize="15sp"
                android:lineSpacingExtra="4dp" />

            <ImageView
                android:id="@+id/image_message_ai"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:adjustViewBounds="true"
                android:maxWidth="260dp"
                android:maxHeight="320dp"
                android:visibility="gone"
                android:scaleType="fitCenter"
                android:layout_gravity="center_horizontal" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical|start"
            android:layout_marginStart="4dp"
            android:layout_marginTop="2dp">

            <TextView
                android:id="@+id/btn_ai_prev"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:text="‹"
                android:textColor="#A0ABC0"
                android:textSize="18sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tv_ai_branch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1/2"
                android:textColor="#708090"
                android:textSize="11sp"
                android:layout_marginHorizontal="2dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/btn_ai_next"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:text="›"
                android:textColor="#A0ABC0"
                android:textSize="18sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <Space
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/btn_ai_copy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="❏"
                android:textColor="#A0ABC0"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btn_ai_regenerate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"
                android:text="↻"
                android:textColor="#A0ABC0"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- サジェスト返信用のコンテナ -->
        <LinearLayout
            android:id="@+id/layout_suggestions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="6dp"
            android:visibility="gone">

            <!-- 3つの選択肢ボタン -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/btn_suggest_a"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    android:background="@drawable/bg_glass_panel"
                    android:paddingVertical="8dp"
                    android:paddingHorizontal="12dp"
                    android:textColor="#00F0FF"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:gravity="center_vertical" />

                <TextView
                    android:id="@+id/btn_suggest_b"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    android:background="@drawable/bg_glass_panel"
                    android:paddingVertical="8dp"
                    android:paddingHorizontal="12dp"
                    android:textColor="#00F0FF"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:gravity="center_vertical" />

                <TextView
                    android:id="@+id/btn_suggest_c"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_glass_panel"
                    android:paddingVertical="8dp"
                    android:paddingHorizontal="12dp"
                    android:textColor="#00F0FF"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:gravity="center_vertical" />
            </LinearLayout>

            <!-- 右側の追加魔法石コスト表示 -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginStart="12dp"
                android:padding="6dp"
                android:background="@drawable/bg_glass_panel">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💎"
                    android:textSize="16sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+10"
                    android:textColor="#FFFF00"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- ユーザーメッセージコンテナ -->
    <LinearLayout
        android:id="@+id/container_user"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="start"
        android:visibility="gone">

        <TextView
            android:id="@+id/text_message_user"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_chat_bubble_user"
            android:paddingHorizontal="14dp"
            android:paddingVertical="10dp"
            android:textColor="@android:color/white"
            android:textSize="15sp"
            android:lineSpacingExtra="4dp" />

        <LinearLayout
            android:id="@+id/layout_user_gift"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_gravity="end"
            android:layout_marginTop="4dp"
            android:paddingHorizontal="10dp"
            android:paddingVertical="6dp"
            android:visibility="gone">
            <TextView
                android:id="@+id/tv_user_gift_icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎁"
                android:textSize="16sp"/>
            <TextView
                android:id="@+id/tv_user_gift_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#00F0FF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginStart="6dp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical|start"
            android:layout_marginStart="4dp"
            android:layout_marginTop="2dp">

            <TextView
                android:id="@+id/btn_user_edit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"
                android:text="✎"
                android:textColor="#A0ABC0"
                android:textSize="14sp" />

            <Space
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/btn_user_copy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="❏"
                android:textColor="#A0ABC0"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btn_user_prev"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:text="‹"
                android:textColor="#A0ABC0"
                android:textSize="18sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tv_user_branch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1/2"
                android:textColor="#708090"
                android:textSize="11sp"
                android:layout_marginHorizontal="2dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/btn_user_next"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:text="›"
                android:textColor="#A0ABC0"
                android:textSize="18sp"
                android:textStyle="bold"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
