<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#131314"
    android:padding="16dp">

    <TextView
        android:id="@+id/tv_editor_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="タグの編集"
        android:textColor="#8AB4F8"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="タグ名"
        android:textColor="#9AA0A6"
        android:textSize="12sp"
        android:layout_marginBottom="4dp" />

    <EditText
        android:id="@+id/et_tag_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/rounded_rect_bg_dark"
        android:hint="タグ名を入力..."
        android:inputType="text"
        android:padding="12dp"
        android:textColor="@android:color/white"
        android:textColorHint="#9AA0A6"
        android:textSize="16sp"
        android:layout_marginBottom="16dp" />

    <!-- 自動付与タグの設定セクション -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="このタグを持つ画像が「自動的に持つタグ」（属性の継承）"
        android:textColor="#9AA0A6"
        android:textSize="12sp"
        android:layout_marginBottom="4dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/rounded_rect_bg_dark"
        android:padding="8dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/tv_implied_tags_display"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="なし"
            android:textColor="#8AB4F8"
            android:textSize="14sp"
            android:padding="8dp" />

        <Button
            android:id="@+id/btn_edit_implied_tags"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="＋ 自動付与するタグを選択"
            android:textColor="#8AB4F8"
            android:textSize="12sp" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="AI召喚用プロンプト設定"
        android:textColor="#9AA0A6"
        android:textSize="12sp"
        android:layout_marginBottom="4dp" />

    <EditText
        android:id="@+id/et_prompt_input"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@drawable/rounded_rect_bg_dark"
        android:gravity="top"
        android:hint="このタグのAIに対する意味（設定）を手動で入力するか、下のボタンからAIに生成させてください。\n例: 水着を着ている、ツンデレな性格など"
        android:inputType="textMultiLine"
        android:minLines="5"
        android:padding="16dp"
        android:textColor="@android:color/white"
        android:textColorHint="#9AA0A6"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/tv_counter"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="0 文字 | 約 0 トークン"
        android:textColor="#9AA0A6"
        android:textSize="12sp"
        android:gravity="end"
        android:layout_marginTop="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="16dp">

        <TextView
            android:id="@+id/tv_local_card_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="紐付けられたカード: なし"
            android:textColor="#FDD663"
            android:textSize="12sp"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btn_link_local_card"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="🎴 Prompt Builder のカードと紐付ける"
            android:textColor="#8AB4F8"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btn_ai_generate"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="✨ AIで自動生成する"
            android:textColor="#131314"
            android:textStyle="bold"
            android:backgroundTint="#8AB4F8"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btn_migrate"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="🔄 このタグを他のタグへ移住する"
            android:textColor="#8AB4F8"
            app:strokeColor="#8AB4F8"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btn_delete"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="🗑️ このタグを完全に削除する"
            android:textColor="#F28B82"
            app:strokeColor="#F28B82"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btn_save"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="保存する"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:backgroundTint="#1E1F20" />
    </LinearLayout>

</LinearLayout>
