<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0B0F19">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#151A28"
        app:titleTextColor="#00F0FF"
        app:layout_constraintTop_toTopOf="parent">

        <!-- ツールバー内にお気に入り追加ボタンを配置 -->
        <ImageButton
            android:id="@+id/btn_add_favorite_folder"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="end"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/btn_star"
            app:tint="#FFD700"
            android:visibility="gone"
            android:contentDescription="お気に入り追加" />
    </androidx.appcompat.widget.Toolbar>

    <LinearLayout
        android:id="@+id/sort_panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:background="#0F1423"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <TextView
            android:id="@+id/btn_sort_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="名前 ▲"
            android:textColor="#00F0FF"
            android:gravity="center"
            android:padding="12dp"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="?attr/selectableItemBackground" />

        <TextView
            android:id="@+id/btn_sort_date"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="更新日 -"
            android:textColor="#8892B0"
            android:gravity="center"
            android:padding="12dp"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="?attr/selectableItemBackground" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/file_recycler_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:padding="4dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/sort_panel"
        app:layout_constraintBottom_toTopOf="@id/bottom_panel" />

    <LinearLayout
        android:id="@+id/bottom_panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="#151A28"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:id="@+id/selected_count_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="選択中: 0"
            android:textColor="#00F0FF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_gravity="center_vertical"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_add_selected"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="追加する"
            android:textStyle="bold"
            app:cornerRadius="8dp"
            app:backgroundTint="#FF003C"
            android:textColor="#FFFFFF" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
