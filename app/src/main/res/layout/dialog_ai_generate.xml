<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#131314">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AI生成の設定"
            android:textColor="#8AB4F8"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp"/>

        <!-- モデル選択セクション -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="#1E1F20"
            app:strokeWidth="1dp"
            app:strokeColor="#338AB4F8"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="推論エンジン"
                        android:textColor="#9AA0A6"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_usage_counter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="OR: 0/0"
                        android:textColor="#FDD663"
                        android:textSize="11sp"
                        android:visibility="gone" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_model_info"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Model: GROK / grok-4-1"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_change_model"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="🤖 生成モデルを変更する"
                    android:textColor="#8AB4F8"
                    app:strokeColor="#8AB4F8"
                    app:cornerRadius="12dp"
                    app:icon="@android:drawable/ic_menu_manage"
                    app:iconTint="#8AB4F8" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 指示プロファイル選択 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="指示プロファイル"
            android:textColor="#9AA0A6"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:layout_marginBottom="16dp">
            <com.google.android.material.chip.ChipGroup
                android:id="@+id/cg_prompt_profiles"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                app:selectionRequired="true" />
        </HorizontalScrollView>

        <!-- 指示入力セクション -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="追加の指示（例: 活発な感じで）"
            android:textColorHint="#9AA0A6"
            app:boxStrokeColor="#8AB4F8"
            app:hintTextColor="#8AB4F8"
            app:boxBackgroundColor="#1E1F20"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp"
            android:layout_marginBottom="16dp"
            style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_instruction"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:inputType="textMultiLine"
                android:minLines="2" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- オプションセクション -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="#1E1F20"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp">

                <com.google.android.material.checkbox.MaterialCheckBox
                    android:id="@+id/cb_use_tag_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="入力中の「タグ名」を対象にする"
                    android:checked="true"
                    android:textColor="#FFFFFF"
                    app:buttonTint="#8AB4F8" />

                <com.google.android.material.checkbox.MaterialCheckBox
                    android:id="@+id/cb_use_existing"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="既存のプロンプト設定をベースにする"
                    android:textColor="#FFFFFF"
                    app:buttonTint="#8AB4F8" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 画像選択セクション -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_pick_image"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🖼️ 画像を選ぶ（任意）"
                android:textColor="#9AA0A6" />

            <Space
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_selected_image"
                android:layout_width="60dp"
                android:layout_height="60dp"
                app:cardCornerRadius="8dp"
                android:visibility="gone">
                <ImageView
                    android:id="@+id/iv_selected_image"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop" />
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- アクションボタン -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_cancel"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="60dp"
                android:text="キャンセル"
                android:textColor="#9AA0A6"
                android:layout_marginEnd="8dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_generate"
                android:layout_width="140dp"
                android:layout_height="60dp"
                android:text="✨ 錬成開始"
                android:textColor="#131314"
                android:textStyle="bold"
                app:backgroundTint="#8AB4F8"
                app:cornerRadius="30dp" />
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
