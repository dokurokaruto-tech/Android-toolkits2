<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- ダークモード(DayNight)を廃止し、常に同じテーマ(Darkベース)にする -->
    <style name="Base.Theme.Kennys_dokidoki_wallpaper" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">#00F0FF</item>
        <item name="colorSurface">#1A2235</item>
        <item name="android:colorBackground">#121212</item>
    </style>

    <style name="Theme.Kennys_dokidoki_wallpaper" parent="Base.Theme.Kennys_dokidoki_wallpaper" />

    <!-- AIチャットオーバーレイ用の透明なテーマ -->
    <style name="Theme.TransparentOverlay" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsFloating">false</item>
        <item name="android:backgroundDimEnabled">false</item>
        <item name="android:windowShowWallpaper">true</item>
        <!-- ステータスバーとナビゲーションバーを透明に -->
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <!-- タグ編集画面用のテーマ：背後のアプリ画面を動かさないように設定 -->
    <style name="Theme.TagEditorOverlay" parent="Theme.TransparentOverlay">
        <!-- windowShowWallpaperをfalseにすることで、アプリ内で開いた時に背後のActivityを維持させるわ -->
        <item name="android:windowShowWallpaper">false</item>
        <!-- 背景を少し暗くして編集画面を目立たせるわね -->
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:backgroundDimAmount">0.7</item>
    </style>

    <!-- ペルソナダイアログ用の透明テーマ -->
    <style name="Theme_TransparentDialog" parent="Theme.AppCompat.Dialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:backgroundDimAmount">0.6</item>
    </style>
</resources>